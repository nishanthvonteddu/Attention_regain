# Public client-safe configuration
NEXT_PUBLIC_APP_NAME=Attention Regain
NEXT_PUBLIC_DEFAULT_GOAL=stay close to the material when attention slips
NEXT_PUBLIC_ENABLE_UPLOADS=true

# Runtime mode
ATTENTION_REGAIN_ENV=local
ENABLE_LIVE_GENERATION=false
ENABLE_RETRIEVAL_PIPELINE=false
ENABLE_VISION_FALLBACK=false
ENABLE_AWS_SERVICES=false
ENABLE_DATABASE=false

# Text generation
NVIDIA_TEXT_API_KEY=
NVIDIA_TEXT_MODEL=meta/llama-3.1-70b-instruct

# Legacy compatibility for earlier local setups
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# Retrieval pipeline
NVIDIA_EMBEDDING_API_KEY=
NVIDIA_EMBEDDING_MODEL=nvidia/llama-3.2-nemoretriever-300m-embed-v1
NVIDIA_RERANK_API_KEY=
NVIDIA_RERANK_MODEL=nv-rerank-qa-mistral-4b:1

# Vision fallback
NVIDIA_VISION_API_KEY=
NVIDIA_VISION_MODEL=meta/llama-3.2-90b-vision-instruct

# Planned AWS and persistence settings
AWS_REGION=
AWS_S3_BUCKET_DOCUMENTS=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_COGNITO_USER_POOL_ID=
AWS_COGNITO_CLIENT_ID=
AWS_COGNITO_DOMAIN=
AUTH_CALLBACK_PATH=/auth/callback
AUTH_SIGN_OUT_PATH=/auth/sign-out
AUTH_PROTECTED_HOME_PATH=/app
AUTH_PUBLIC_HOME_PATH=/
AUTH_SESSION_COOKIE_NAME=attention_regain_session
QUEUE_URL_DOCUMENT_PROCESSING=
DATABASE_URL=
ATTENTION_REGAIN_DATA_DIR=
